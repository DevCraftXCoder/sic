# SIC — environment variables
# Copy to .env and fill in secret values.
# Price IDs are pre-populated (test mode, FrancoisMusic account).
#
# Generate a new SIC_AUTH_SECRET:
#   python -c "import secrets; print(secrets.token_hex(32))"

# ── Runtime environment ───────────────────────────────────────────────────────
# Set to "production" in production deployments.
# Startup checks and stricter validation are gated on this value.
SIC_ENV=production

# ── Auth ─────────────────────────────────────────────────────────────────────
# HMAC secret for magic-link tokens and session cookies.
# Leave unset to auto-generate on first run (persisted to ~/.sic/auth.key).
SIC_AUTH_SECRET=

# ── Stripe billing ───────────────────────────────────────────────────────────
# Test key: copy from `stripe config --list` (sk_test_51...)
# Live key: copy from Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...

# Pre-created product prices (test mode).
STRIPE_PRICE_TEAM=price_1TSSonLY2nLyoJCY9v0058dX
STRIPE_PRICE_STUDIO=price_1TSSonLY2nLyoJCY0CLBlnHZ

# Webhook signing secret.
# For local dev: run `stripe listen --forward-to localhost:9888/api/billing/webhook`
# and copy the whsec_... value it prints.
# For production: create a webhook endpoint in Stripe Dashboard and copy the secret.
STRIPE_WEBHOOK_SECRET=whsec_...

# ── SSO ──────────────────────────────────────────────────────────────────────
# Public base URL of this SIC instance (used for SAML ACS + OIDC redirect URIs).
# Example: https://sic.yourcompany.com
SIC_SSO_BASE_URL=http://localhost:9888

# Optional: SAML SP signing cert/key (for signed AuthnRequests).
# Leave blank to skip SP request signing (IdP signature validation still enforced).
SIC_SAML_SP_CERT=
SIC_SAML_SP_KEY=

# ── Email delivery ───────────────────────────────────────────────────────────
# Resend API key — used for magic-link delivery and alert emails.
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_...

# Sender address for all SIC emails (must be a verified domain in Resend).
SIC_ALERT_FROM=sic-alerts@hexstrike.ai

# Optional: alert recipients for critical_finding / unauthorized_attempt events.
# Comma-separated list of email addresses.
SIC_ALERT_EMAIL=

# Optional: SMTP fallback (used if RESEND_API_KEY is not set).
SIC_SMTP_HOST=
SIC_SMTP_PORT=587
SIC_SMTP_USER=
SIC_SMTP_PASS=

# ── Admin ─────────────────────────────────────────────────────────────────────
# Comma-separated list of admin emails allowed to request magic links.
SIC_ADMIN_EMAILS=

# Set to "1" to include the magic link in the /auth/request-link response (dev only).
SIC_DEV_MODE=

# ── Server ───────────────────────────────────────────────────────────────────
SIC_HOST=127.0.0.1
SIC_PORT=9888
SIC_IP_ALLOWLIST=127.0.0.1/8,::1
SIC_DENY_DEFAULT=true
